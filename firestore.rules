rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isAdmin() {
      return isSignedIn() &&
        userEmail() == "imedashviligio27@gmail.com";
    }

    function isDoctor() {
      return isSignedIn() &&
        userEmail() == "eringorokva@gmail.com";
    }

    function isRegistrar() {
      return isSignedIn() && (
        userEmail() == "emergencyhtmc14@gmail.com"
      );
    }

    function isUser() {
      return isSignedIn() &&
        userEmail() == "nino.nikaberidze@gmail.com";
    }

    function isAllowedUser() {
      return isAdmin() || isDoctor() || isRegistrar() || isUser();
    }

    function canCreateRequests() {
      return isAdmin() || isDoctor() || isUser();
    }

    function canUpdateRequests() {
      return isAdmin() || isDoctor() || isRegistrar();
    }

    function canCreateAuditLogs() {
      return isAdmin() || isDoctor() || isRegistrar() || isUser();
    }

    match /users/{userId} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isAllowedUser();
      allow create: if canCreateRequests();
      allow update: if canUpdateRequests();
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if canCreateAuditLogs();
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }
  }
}
