rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isAllowedUser() {
      return isSignedIn() && (
        userEmail() == "imedashviligio27@gmail.com" ||
        userEmail() == "nino.nikaberidze@gmail.com" ||
        userEmail() == "eringorokva@gmail.com" ||
        userEmail() == "emergencyhtmc14@gmail.com"
      );
    }

    function isReadOnlyAdmin() {
      return isSignedIn() &&
        userEmail() == "nino.nikaberidze@gmail.com";
    }

    function canWriteData() {
      return isSignedIn() && (
        userEmail() == "imedashviligio27@gmail.com" ||
        userEmail() == "eringorokva@gmail.com" ||
        userEmail() == "emergencyhtmc14@gmail.com"
      );
    }

    match /users/{userId} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser() && request.auth.uid == userId;
      allow delete: if canWriteData() && !isReadOnlyAdmin();
    }

    match /{document=**} {
      allow read: if isAllowedUser();
      allow write: if canWriteData();
    }
  }
}
