rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isVerifiedGoogleUser() {
      return isSignedIn() &&
        request.auth.token.email_verified == true;
    }

    function isPasswordUser() {
      return isSignedIn() &&
        request.auth.token.firebase != null &&
        request.auth.token.firebase.sign_in_provider == "password";
    }

    function isAllowedProvider() {
      return isVerifiedGoogleUser() || isPasswordUser();
    }

    function isAdmin() {
      return isAllowedProvider() &&
        userEmail() == "imedashviligio27@gmail.com";
    }

    function isDoctor() {
      return isAllowedProvider() &&
        userEmail() == "eringorokva@gmail.com";
    }

    function isRegistrar() {
      return isAllowedProvider() &&
        userEmail() == "emergencyhtmc14@gmail.com";
    }

    function isAllowedUser() {
      return isAdmin() || isDoctor() || isRegistrar();
    }

    function isOwner() {
      return isSignedIn() && (
        resource.data.createdByUserId == request.auth.uid ||
        resource.data.createdByUserEmail == userEmail()
      );
    }

    function isNewOwner() {
      return isSignedIn() &&
        request.resource.data.createdByUserId == request.auth.uid &&
        request.resource.data.createdByUserEmail == userEmail();
    }

    function ownRole() {
      return isAdmin() ? "admin" :
        isDoctor() ? "doctor" :
        isRegistrar() ? "registrar" :
        "";
    }

    match /users/{userId} {
      allow read: if isAllowedUser() &&
        (isAdmin() || request.auth.uid == userId);

      allow create: if isAllowedUser() &&
        request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == userEmail() &&
        request.resource.data.role == ownRole();

      allow update: if isAllowedUser() &&
        (
          isAdmin() ||
          (
            request.auth.uid == userId &&
            request.resource.data.uid == request.auth.uid &&
            request.resource.data.email == userEmail() &&
            request.resource.data.role == ownRole()
          )
        );
    }

    match /requests/{requestId} {
      allow read: if isAllowedUser() &&
        (isAdmin() || isRegistrar() || isOwner());

      allow create: if isAllowedUser() &&
        (isAdmin() || isDoctor()) &&
        isNewOwner();

      allow update: if isAllowedUser() &&
        (
          isAdmin() ||
          isRegistrar() ||
          (isDoctor() && isOwner() && resource.data.currentStatus == "ახალი")
        );

      allow delete: if isAllowedUser() && isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAllowedUser();
    }

    match /settings/{settingId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser() && isAdmin();
    }
  }
}
