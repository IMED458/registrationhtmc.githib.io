rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isAllowedProvider() {
      return isSignedIn() && (
        request.auth.token.email_verified == true ||
        (
          request.auth.token.firebase != null &&
          request.auth.token.firebase.sign_in_provider == "password"
        )
      );
    }

    function isAdmin() {
      return isAllowedProvider() &&
        userEmail() == "imedashviligio27@gmail.com";
    }

    function isDoctor() {
      return isAllowedProvider() &&
        userEmail() == "eringorokva@gmail.com";
    }

    function isRegistrar() {
      return isAllowedProvider() &&
        userEmail() == "emergencyhtmc14@gmail.com";
    }

    function isAllowedUser() {
      return isAdmin() || isDoctor() || isRegistrar();
    }

    function isRequestOwner() {
      return isSignedIn() && (
        resource.data.createdByUserId == request.auth.uid ||
        resource.data.createdByUserEmail == userEmail()
      );
    }

    function registrarCommentRequired() {
      return resource.data.lastRegistrarEditAt != null;
    }

    function registrarCanMarkInReview() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "currentStatus",
        "updatedAt"
      ]) &&
        resource.data.currentStatus == "ახალი" &&
        request.resource.data.currentStatus == "განხილვაშია";
    }

    function registrarEditFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "currentStatus",
        "finalDecision",
        "registrarComment",
        "registrarName",
        "formFillerName",
        "pendingRegistrarUpdate",
        "lastRegistrarEditAt",
        "lastRegistrarEditByUserId",
        "lastRegistrarEditByUserName",
        "lastRegistrarEditByUserEmail",
        "adminConfirmationStatus",
        "adminConfirmedAt",
        "adminConfirmedByUserId",
        "adminConfirmedByUserName",
        "requiresRegistrarAction",
        "pendingDoctorEdit",
        "updatedAt"
      ]);
    }

    function registrarEditCommentIsValid() {
      return request.resource.data.registrarComment is string &&
        (
          !registrarCommentRequired() ||
          request.resource.data.registrarComment.size() > 0
        );
    }

    function pendingRegistrarUpdateIsValid() {
      return request.resource.data.pendingRegistrarUpdate != null &&
        request.resource.data.pendingRegistrarUpdate.currentStatus == request.resource.data.currentStatus &&
        request.resource.data.pendingRegistrarUpdate.requestedByUserId == request.auth.uid &&
        request.resource.data.pendingRegistrarUpdate.requestedByUserName is string &&
        request.resource.data.pendingRegistrarUpdate.registrarComment is string &&
        (
          !registrarCommentRequired() ||
          request.resource.data.pendingRegistrarUpdate.registrarComment.size() > 0
        );
    }

    function registrarUpdateValid() {
      return registrarEditFieldsOnly() &&
        registrarEditCommentIsValid() &&
        pendingRegistrarUpdateIsValid() &&
        request.resource.data.lastRegistrarEditByUserId == request.auth.uid &&
        request.resource.data.lastRegistrarEditByUserName is string &&
        request.resource.data.lastRegistrarEditByUserEmail == userEmail() &&
        request.resource.data.adminConfirmationStatus == "pending" &&
        request.resource.data.requiresRegistrarAction == false &&
        request.resource.data.pendingDoctorEdit == null;
    }

    function doctorEditFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "patientData",
        "diagnosis",
        "icdCode",
        "diagnoses",
        "requiresRegistrarAction",
        "pendingDoctorEdit",
        "lastDoctorEditAt",
        "lastDoctorEditByUserId",
        "lastDoctorEditByUserName",
        "lastDoctorEditByUserEmail",
        "lastDoctorEditComment",
        "adminConfirmationStatus",
        "adminConfirmedAt",
        "adminConfirmedByUserId",
        "adminConfirmedByUserName",
        "updatedAt"
      ]);
    }

    function doctorUpdateValid() {
      return isRequestOwner() &&
        doctorEditFieldsOnly() &&
        request.resource.data.patientData != null &&
        request.resource.data.lastDoctorEditComment is string &&
        request.resource.data.lastDoctorEditComment.size() > 0 &&
        request.resource.data.lastDoctorEditByUserId == request.auth.uid &&
        request.resource.data.lastDoctorEditByUserName is string &&
        request.resource.data.lastDoctorEditByUserEmail == userEmail() &&
        request.resource.data.pendingDoctorEdit != null &&
        request.resource.data.pendingDoctorEdit.comment is string &&
        request.resource.data.pendingDoctorEdit.comment.size() > 0 &&
        request.resource.data.pendingDoctorEdit.editedByUserId == request.auth.uid &&
        request.resource.data.pendingDoctorEdit.editedByUserName is string &&
        request.resource.data.pendingDoctorEdit.editedByUserEmail == userEmail() &&
        request.resource.data.adminConfirmationStatus == "pending" &&
        request.resource.data.requiresRegistrarAction == false;
    }

    match /users/{userId} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser() && request.auth.uid == userId;
    }

    match /requests/{requestId} {
      allow read: if isAllowedUser();

      allow create: if (isAdmin() || isDoctor()) &&
        request.resource.data.createdByUserId == request.auth.uid &&
        request.resource.data.createdByUserEmail == userEmail();

      allow update: if isAdmin() ||
        (
          isRegistrar() &&
          (
            registrarCanMarkInReview() ||
            registrarUpdateValid()
          )
        ) ||
        (
          isDoctor() &&
          doctorUpdateValid()
        );

      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAllowedUser();
    }

    match /settings/{settingId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }
  }
}
