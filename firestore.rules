rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isVerifiedEmail() {
      return isAuthenticated() &&
        request.auth.token.email != null &&
        request.auth.token.email_verified == true;
    }

    function isPasswordProvider() {
      return isAuthenticated() &&
        request.auth.token.firebase != null &&
        request.auth.token.firebase.sign_in_provider == "password";
    }

    function hasGlobalSettings() {
      return exists(/databases/$(database)/documents/settings/global);
    }

    function globalSettings() {
      return get(/databases/$(database)/documents/settings/global).data;
    }

    function emailRole() {
      return request.auth.token.email == "imedashviligio27@gmail.com" ? "admin" :
        request.auth.token.email == "eringorokva@gmail.com" ? "doctor" :
        request.auth.token.email == "emergencyhtmc14@gmail.com" ? "registrar" :
        "";
    }

    function isAllowedEmailCandidate() {
      return isAuthenticated() &&
        request.auth.token.email != null &&
        emailRole() != "" &&
        (isVerifiedEmail() || isPasswordProvider());
    }

    function isEmailDisabled() {
      return isAllowedEmailCandidate() &&
        hasGlobalSettings() &&
        ('disabledEmails' in globalSettings()) &&
        request.auth.token.email in globalSettings().disabledEmails;
    }

    function isAllowedEmail() {
      return isAllowedEmailCandidate() && !isEmailDisabled();
    }

    function hasUserProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return hasUserProfile()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : emailRole();
    }

    function hasRole(role) {
      return isAllowedEmail() && getUserRole() == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isRegistrar() {
      return hasRole('registrar');
    }

    function isDoctorOrNurse() {
      return hasRole('doctor') || hasRole('nurse');
    }

    function requestBelongsToCurrentUser(requestData) {
      return isAuthenticated() && (
        requestData.createdByUserId == request.auth.uid ||
        (
          request.auth.token.email != null &&
          requestData.createdByUserEmail == request.auth.token.email
        )
      );
    }

    function isRequestOwner() {
      return requestBelongsToCurrentUser(resource.data);
    }

    function newRequestBelongsToCurrentUser() {
      return request.auth.token.email != null &&
        request.resource.data.createdByUserId == request.auth.uid &&
        request.resource.data.createdByUserEmail == request.auth.token.email;
    }

    function ownUserProfileMatchesAllowedRole(userId) {
      return request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.role == emailRole();
    }

    match /users/{userId} {
      allow read: if isAllowedEmail() && (isAdmin() || request.auth.uid == userId);
      allow create: if isAllowedEmail() && ownUserProfileMatchesAllowedRole(userId);
      allow update: if isAllowedEmail() && (isAdmin() || ownUserProfileMatchesAllowedRole(userId));
    }

    match /requests/{requestId} {
      allow read: if isAllowedEmail() && (
        isAdmin() ||
        isRegistrar() ||
        isRequestOwner()
      );
      allow create: if isAllowedEmail() &&
        (isDoctorOrNurse() || isAdmin()) &&
        newRequestBelongsToCurrentUser();
      allow update: if isAllowedEmail() && (
        isRegistrar() ||
        isAdmin() ||
        (isDoctorOrNurse() && isRequestOwner() && resource.data.currentStatus == 'ახალი')
      );
      allow delete: if isAllowedEmail() && isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAllowedEmail();
    }

    match /settings/{settingId} {
      allow read: if isAllowedEmailCandidate();
      allow write: if isAdmin();
    }
  }
}
