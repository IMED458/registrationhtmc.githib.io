rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function staticRole() {
      return userEmail() == "imedashviligio27@gmail.com" ? "admin" :
        userEmail() == "nino.nikaberidze@gmail.com" ? "manager" :
        userEmail() == "eringorokva@gmail.com" ? "doctor" :
        userEmail() == "emergencyhtmc14@gmail.com" ? "registrar" :
        userEmail() == "giorgit@registrationhtmc.local" ? "shift_manager" :
        userEmail() == "gulshanm@registrationhtmc.local" ? "shift_manager" :
        userEmail() == "ninoch@registrationhtmc.local" ? "shift_manager" :
        "";
    }

    function ownUserDocExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function ownUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function dynamicRole() {
      return ownUserDocExists() && ownUserDoc().isActive != false && ownUserDoc().role != null
        ? ownUserDoc().role
        : "";
    }

    function currentRole() {
      return dynamicRole() != "" ? dynamicRole() : staticRole();
    }

    function hasGlobalSettings() {
      return exists(/databases/$(database)/documents/settings/global);
    }

    function globalSettings() {
      return hasGlobalSettings()
        ? get(/databases/$(database)/documents/settings/global).data
        : {};
    }

    function disabledEmails() {
      return hasGlobalSettings() && ('disabledEmails' in globalSettings())
        ? globalSettings().disabledEmails
        : [];
    }

    function isDisabled() {
      return isSignedIn() && userEmail() in disabledEmails();
    }

    function isAllowedUser() {
      return isSignedIn() && !isDisabled() && (staticRole() != "" || dynamicRole() != "");
    }

    function isAdmin() {
      return isAllowedUser() && currentRole() == "admin";
    }

    function isDoctorOrNurse() {
      return isAllowedUser() && (
        currentRole() == "doctor" ||
        currentRole() == "nurse"
      );
    }

    function isRegistrar() {
      return isAllowedUser() && currentRole() == "registrar";
    }

    function isManagerLike() {
      return isAllowedUser() && (
        currentRole() == "manager" ||
        currentRole() == "user" ||
        currentRole() == "shift_manager"
      );
    }

    function canCreateRequests() {
      return isAdmin() || isDoctorOrNurse() || isManagerLike();
    }

    function canUpdateRequests() {
      return isAdmin() || isDoctorOrNurse() || isRegistrar() || isManagerLike();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isAllowedUser();
      allow create: if canCreateRequests();
      allow update: if canUpdateRequests();
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAllowedUser();
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }
  }
}
